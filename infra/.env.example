# =============================================================================
# notip-infra — environment variables template
# Copy to .env and fill in values. NEVER commit .env.
# Secrets (marked ⚠) are also written to secrets/ by scripts/bootstrap.sh
# =============================================================================

# --- Infrastructure image tags ---
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.5
POSTGRES_IMAGE=postgres:18.3-alpine
TIMESCALE_IMAGE=timescale/timescaledb:latest-pg17
NATS_IMAGE=nats:2.12-alpine

# --- Service image tags (published to ghcr.io/notipswe) ---
MGMT_API_IMAGE=ghcr.io/notipswe/notip-management-api:latest
DATA_API_IMAGE=ghcr.io/notipswe/notip-data-api:latest
DATA_CONSUMER_IMAGE=ghcr.io/notipswe/notip-data-consumer:latest
PROVISIONING_IMAGE=ghcr.io/notipswe/notip-provisioning-service:latest
FRONTEND_IMAGE=ghcr.io/notipswe/notip-frontend:latest
SIMULATOR_IMAGE=ghcr.io/notipswe/notip-simulator-backend:latest
SIM_CLI_IMAGE=ghcr.io/notipswe/notip-simulator-cli:latest

# --- Keycloak ---
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_ADMIN_USER=admin
# ⚠ also in secrets/keycloak_admin_password
KEYCLOAK_ADMIN_PASSWORD=

# --- Management DB (PostgreSQL) ---
MGMT_DB_HOST=mgmt-db
MGMT_DB_PORT=5432
MGMT_DB_NAME=notip_mgmt
MGMT_DB_USER=notip_mgmt
# ⚠ also in secrets/mgmt_db_password
MGMT_DB_PASSWORD=

# --- Measures DB (TimescaleDB) ---
MEASURES_DB_HOST=measures-db
MEASURES_DB_PORT=5432
MEASURES_DB_NAME=notip_measures
MEASURES_DB_USER=notip_measures
# ⚠ also in secrets/measures_db_password
MEASURES_DB_PASSWORD=

# --- NATS ---
NATS_URL=nats://nats:4222

# --- Management API ---
MGMT_API_PORT=3001
# ⚠ AES-256 key for encrypting gateway AES keys at rest (32 hex bytes)
# LOSS OF THIS KEY = all gateway encryption keys become unrecoverable
DB_ENCRYPTION_KEY=

KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=notip
# ⚠ OAuth2 secret for notip-mgmt-backend service account
KEYCLOAK_MGMT_CLIENT_SECRET=
KEYCLOAK_MGMT_CLIENT_ID=notip-mgmt-backend

# --- Data API ---
DATA_API_PORT=3002

# --- Provisioning Service ---
PROVISIONING_PORT=3004

# --- Simulator ---
# Platform for the simulator container. Default is linux/amd64.
# Override to linux/arm64 when building locally on Apple Silicon (M1/M2/M3/M4/M5).
SIMULATOR_PLATFORM=linux/amd64
SIMULATOR_PORT=8090
# ⚠ OAuth2 secret for notip-simulator-backend service account
KEYCLOAK_SIMULATOR_CLIENT_SECRET=
KEYCLOAK_SIMULATOR_CLIENT_ID=notip-simulator-backend

# --- Keycloak DB ---
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
# ⚠ also in secrets/keycloak_db_password
KEYCLOAK_DB_PASSWORD=
