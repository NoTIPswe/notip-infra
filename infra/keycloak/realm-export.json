{
  "realm": "notip",
  "displayName": "NoTIP",
  "loginTheme": "notip",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": true,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 10,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 1800,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "defaultRoles": [],
  "roles": {
    "realm": [
      { "name": "system_admin",  "composite": false },
      { "name": "tenant_admin",  "composite": false },
      { "name": "tenant_user",   "composite": false },
      { "name": "sim_admin",     "composite": false }
    ]
  },
  "clientScopes": [
    {
      "name": "notip-claims",
      "description": "Injects tenant_id and role as top-level JWT claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "id",
            "claim.name": "sub",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute":       "username",
            "claim.name":           "username",
            "jsonType.label":       "String",
            "id.token.claim":       "true",
            "access.token.claim":   "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute":       "tenant_id",
            "claim.name":           "tenant_id",
            "jsonType.label":       "String",
            "id.token.claim":       "true",
            "access.token.claim":   "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute":       "role",
            "claim.name":           "role",
            "jsonType.label":       "String",
            "id.token.claim":       "true",
            "access.token.claim":   "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "mgmt-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "notip-mgmt-backend",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "notip-roles",
      "description": "Adds realm and client role claims to access tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "user.attribute": "foo"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "user.attribute": "foo"
          }
        },
        {
          "name": "audience resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "notip-claims",
    "notip-roles"
  ],
  "users": [
    {
      "username": "__KEYCLOAK_ADMIN_USER__",
      "enabled": true,
      "emailVerified": true,
      "attributes": {
        "role": [
          "system_admin"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "__KEYCLOAK_ADMIN_PASSWORD__",
          "temporary": false
        }
      ],
      "realmRoles": [
        "system_admin"
      ],
      "clientRoles": {
        "realm-management": [
          "impersonation"
        ]
      }
    }
  ],
  "clients": [
    {
      "clientId": "notip-frontend",
      "name": "NoTIP Web Application",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:4200"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "notip-claims", "notip-roles"
      ]
    },
    {
      "clientId": "notip-mgmt-backend",
      "name": "Management API Service Account",
      "description": "Used by Management API to call Keycloak Admin REST API (user/client CRUD)",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "REPLACE_ME",
      "defaultClientScopes": [
        "notip-claims", "notip-roles"
      ]
    },
    {
      "clientId": "notip-simulator-backend",
      "name": "Simulator Backend Service Account",
      "description": "Used by Simulator to register/decommission gateways via Management API",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "REPLACE_ME",
      "defaultClientScopes": [
        "notip-claims", "notip-roles"
      ]
    }
  ]
}
