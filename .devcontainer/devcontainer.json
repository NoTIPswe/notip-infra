{
    "name": "NoTIP Infra Dev",
    "image": "ghcr.io/notipswe/notip-infra-dev:v0.0.1",
    "remoteUser": "dev",
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "postCreateCommand": "pre-commit install --install-hooks",
    "postStartCommand": "pre-commit install --install-hooks",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "ms-python.python",
                "timonwong.shellcheck",
                "redhat.vscode-yaml"
            ]
        }
    },
    "workspaceFolder": "/workspaces/notip-infra",
    "init": true
}